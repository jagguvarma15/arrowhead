# Copy to .env for local development. Every variable takes the ARROWHEAD_
# prefix. Values here are safe placeholders, not real secrets.

# --- Transport ---
# stdio for Inspector over a pipe; http to serve the streamable endpoint.
ARROWHEAD_TRANSPORT=stdio
ARROWHEAD_HOST=127.0.0.1
ARROWHEAD_PORT=8000
ARROWHEAD_STATELESS_HTTP=true
# Comma-separated Host and Origin allowlists for the HTTP endpoint. Set
# these to your public hostname when deploying behind a proxy.
ARROWHEAD_ALLOWED_HOSTS=
ARROWHEAD_ALLOWED_ORIGINS=

# --- Auth (OAuth 2.1 resource server) ---
# Leave disabled only for local stdio development. The server's public URL
# is always required when enabled.
ARROWHEAD_AUTH_ENABLED=false
ARROWHEAD_SERVER_PUBLIC_URL=https://arrowhead.example.com
# "jwt" verifies against any OAuth 2.1 issuer (bring-your-own-IdP, e.g.
# Keycloak); "workos" wires WorkOS AuthKit, purpose-built for MCP.
ARROWHEAD_OAUTH_PROVIDER=jwt

# jwt provider: issuer, audience (= the canonical resource URI, must equal
# SERVER_PUBLIC_URL's resource), and one key source (JWKS URI preferred).
ARROWHEAD_OAUTH_ISSUER=https://your-idp.example.com
ARROWHEAD_OAUTH_AUDIENCE=https://arrowhead.example.com
ARROWHEAD_OAUTH_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
# ARROWHEAD_OAUTH_PUBLIC_KEY=

# workos provider: the AuthKit domain from the WorkOS dashboard. AuthKit
# serves the OAuth metadata MCP clients need for automatic registration.
# ARROWHEAD_OAUTH_AUTHKIT_DOMAIN=https://your-project.authkit.app

# --- Per-resource authorization (document tools) ---
# JSON policy applied on top of scopes. Empty uses a safe default: any
# authenticated caller may search, read, and scan the corpus, but write
# only within its own "<subject>/" namespace. Ignored when auth is off.
# Example:
# ARROWHEAD_AUTHZ_POLICY={"grants":[{"subject":"*","actions":["read","search","scan"],"prefix":""},{"subject":"*","actions":["write"],"prefix":"${subject}/"}]}
ARROWHEAD_AUTHZ_POLICY=

# --- read_file jail ---
# The only directory read_file may read from.
ARROWHEAD_JAIL_ROOT=sandbox
ARROWHEAD_READ_FILE_MAX_BYTES=1000000

# --- Document corpus (doc_* tools) ---
# The jailed root the document tools operate on, separate from the
# read-only read_file sandbox. Only these extensions are documents.
ARROWHEAD_DOCS_ROOT=documents
ARROWHEAD_DOC_MAX_BYTES=1000000
ARROWHEAD_DOC_ALLOWED_EXTENSIONS=.json,.md,.txt
# Content hardening caps applied to returned document content.
ARROWHEAD_CONTENT_MAX_BYTES=1000000
ARROWHEAD_JSON_MAX_DEPTH=64
ARROWHEAD_JSON_MAX_ELEMENTS=100000

# --- doc_search ---
# Regex is off by default (denial-of-service surface); when enabled it
# runs through a ReDoS-resistant engine with a hard timeout.
ARROWHEAD_SEARCH_REGEX_ENABLED=false
ARROWHEAD_SEARCH_REGEX_TIMEOUT_MS=250
ARROWHEAD_SEARCH_MAX_FILES=2000
ARROWHEAD_SEARCH_MAX_RESULTS=50
ARROWHEAD_SEARCH_MAX_TOTAL_BYTES=200000

# --- doc_scan ---
ARROWHEAD_SCAN_MAX_FILES=2000
ARROWHEAD_SCAN_PER_FILE_MAX_BYTES=1000000
ARROWHEAD_SCAN_TIMEOUT_SECONDS=10
ARROWHEAD_SCAN_MAX_FINDINGS=200

# --- doc_write ---
ARROWHEAD_DOC_WRITE_MAX_BYTES=1000000
ARROWHEAD_DOC_WRITE_QUOTA_BYTES=50000000
# Overwriting asks for confirmation via elicitation; when the client
# cannot elicit, the explicit overwrite flag stands in as the opt-in.
ARROWHEAD_REQUIRE_WRITE_CONFIRMATION=true

# --- safe_fetch ---
ARROWHEAD_FETCH_TIMEOUT_SECONDS=10
ARROWHEAD_FETCH_MAX_RESPONSE_BYTES=1000000
ARROWHEAD_FETCH_MAX_REDIRECTS=3

# --- Egress allowlist (safe_fetch, doc_retrieve) ---
# Comma-separated hostnames the fetch and retrieve tools may reach, enforced
# on every redirect hop. Empty allows any public host; the SSRF guard blocks
# private ranges regardless. Set this to restrict outbound requests to
# approved destinations.
ARROWHEAD_EGRESS_ALLOWED_HOSTS=

# --- calculate ---
ARROWHEAD_EXPRESSION_MAX_LENGTH=200

# --- Abuse controls ---
# Ceilings are calls per caller per minute. Redis, if set, shares the
# buckets across replicas; without it limits apply per process.
ARROWHEAD_RATE_LIMIT_ENABLED=true
ARROWHEAD_SAFE_FETCH_PER_MINUTE=30
ARROWHEAD_CALCULATE_PER_MINUTE=120
ARROWHEAD_READ_FILE_PER_MINUTE=60
ARROWHEAD_DOC_SEARCH_PER_MINUTE=60
ARROWHEAD_DOC_READ_PER_MINUTE=60
ARROWHEAD_DOC_RETRIEVE_PER_MINUTE=30
ARROWHEAD_DOC_SCAN_PER_MINUTE=20
ARROWHEAD_DOC_WRITE_PER_MINUTE=30
# Any tool without an explicit ceiling above falls back to this default.
ARROWHEAD_DEFAULT_TOOL_PER_MINUTE=60
ARROWHEAD_REDIS_URL=redis://localhost:6379/0

# --- Kill switch ---
# Comma-separated tool names to take out of service without a redeploy.
ARROWHEAD_DISABLED_TOOLS=

# --- Tool list cache hint ---
ARROWHEAD_TOOL_LIST_TTL_MS=3600000

# --- Observability (OpenTelemetry) ---
# Set the OTLP/HTTP collector base endpoint to export traces and metrics;
# leave empty and both stay no-op at no cost. Headers are comma-separated
# key=value pairs (e.g. a collector API key). Audit logs are always emitted
# as JSON on stdout for the platform's log drain regardless of this.
ARROWHEAD_OTEL_EXPORTER_OTLP_ENDPOINT=
# ARROWHEAD_OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer your-token
ARROWHEAD_OTEL_SERVICE_NAME=arrowhead
